# LLM API (OpenAI 兼容格式，支持 DeepSeek / 通义千问 / Kimi / 智谱等)
API_BASE_URL=https://api.deepseek.com/v1
API_KEY=sk-your-key-here
MODEL_NAME=deepseek-chat

# Embedding API (用于知识库语义搜索，支持 SiliconFlow / OpenAI / 本地模型)
EMBEDDING_API_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=your-siliconflow-api-key
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
# EMBEDDING_DIM=2560           # 向量维度，需与模型匹配（默认 2560）

# SMTP 邮件（可选，配合 --email 使用）
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=587
# SMTP_SENDER=your-qq@qq.com
# SMTP_AUTH_CODE=your-auth-code-here
# SMTP_RECEIVER=your-qq@qq.com

# 摘要设置
SUMMARY_DAYS=7
SUMMARY_LANGUAGE=zh-CN
PROMPT_NAME=tech-weekly

# LLM 参数（可选）
# LLM_TEMPERATURE=0.3          # 生成温度
# LLM_MAX_TOKENS=4096          # 最大输出 token

# 数据路径（可选，均有默认值）
# DB_PATH=knowledge/pulse.db   # 知识库数据库路径
# OUTPUT_DIR=output             # 文件输出目录
# FEEDS_PATH=feeds.json        # 订阅源配置路径
# PROMPTS_DIR=prompts          # 提示词模板目录
# GITHUB_PAGES_DIR=docs        # GitHub Pages 输出目录
# ENV_PATH=.env                # 环境变量文件路径

# HTTP 设置（可选）
# HTTP_TIMEOUT=15              # 请求超时（秒）
# HTTP_USER_AGENT=Mozilla/5.0 (compatible; Signal/1.0)

# 邮件重试（可选）
# EMAIL_MAX_RETRIES=3          # 最大重试次数
# EMAIL_RETRY_DELAY=10         # 重试间隔（秒）
# EMAIL_SMTP_TIMEOUT=30        # SMTP 超时（秒）

# 并发（可选）
# FETCH_MAX_WORKERS=8          # 并行抓取线程数

# GitHub
GITHUB_REPO_URL=https://github.com/user/repo
